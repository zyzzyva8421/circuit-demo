        {
          "id": "p1",
          "width": 4,
          "height": 4,
          "layoutOptions": { "elk.port.side": "EAST", "elk.port.index": 0 }
        }
      ]
    },
    {
      "id": "n2",
       "width": 80,
       "height": 100,
       "layoutOptions": { "elk.portConstraints": "FIXED_ORDER" },
